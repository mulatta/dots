+		case <-time.After(time.Second):
+		}
+	}
+}
+
+func (b *Backend) runSubscription(
+	ctx context.Context,
+	pubCtx context.Context,
+	events <-chan gonostr.RelayEvent,
+	closed <-chan gonostr.RelayClosed,
+) string {
+	refresh := time.NewTimer(subscriptionRefreshInterval)
+	defer refresh.Stop()
+
+	for {
+		select {
+		case ie, ok := <-events:
+			if !ok {
+				return "events channel closed"
+			}
+
+			if ctx.Err() != nil {
+				return "context cancelled"
+			}
+
+			slog.Debug("nostr: gift wrap received from relay", "relay", ie.Relay.URL, "event_id", ie.ID.Hex())
+			evt := ie.Event
+			b.processGiftWrap(ctx, pubCtx, &evt)
+		case rc, ok := <-closed:
+			if !ok {
+				closed = nil
+				continue
+			}
+			if rc.HandledAuth {
+				continue
+			}
+			relayURL := ""
+			if rc.Relay != nil {
+				relayURL = rc.Relay.URL
+			}
+			slog.Warn("nostr: relay closed subscription", "relay", relayURL, "reason", rc.Reason)
+			return "relay closed subscription"
+		case <-refresh.C:
+			slog.Info("nostr: forcing resubscribe", "reason", "periodic subscription refresh")
+			return "periodic subscription refresh"
+		case <-ctx.Done():
+			return "context cancelled"
+		}
+	}
 }
 
