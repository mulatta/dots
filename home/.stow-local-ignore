# GNU Stow's built-in ignore list, with .gitignore removed so home/.gitignore
# can be linked into ~/.gitignore.
RCS
.+,v

CVS
\.\#.+       # CVS conflict files / emacs lock files
\.cvsignore

\.svn
_darcs
\.hg

\.git
\.gitmodules

# Generated by home-manager activation to expose Nix-built pi extension deps
# next to the hot-reloadable dotfiles sources. Do not stow it into $HOME.
^/\.pi/agent/node_modules$

.+~          # emacs backup files
\#.*\#       # emacs autosave files

^/README.*
^/LICENSE.*
^/COPYING
