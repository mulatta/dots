{
  "version": 3,
  "lines": [
    [
      {
        "id": "1",
        "type": "model",
        "color": "cyan"
      },
      {
        "id": "2",
        "type": "separator"
      },
      {
        "id": "3",
        "type": "custom-command",
        "commandPath": "basename \"$PWD\"",
        "color": "blue",
        "timeout": 500
      },
      {
        "id": "4",
        "type": "separator"
      },
      {
        "id": "5",
        "type": "custom-command",
        "commandPath": "if git rev-parse --is-inside-work-tree >/dev/null 2>&1; then branch=$(git branch --show-current 2>/dev/null); commit=$(git rev-parse --short HEAD 2>/dev/null); echo \"${branch:-detached} | ${commit:-unknown}\"; else echo \"None | unknown\"; fi",
        "color": "magenta",
        "timeout": 1000
      }
    ],
    [
      {
        "id": "6",
        "type": "context-length",
        "color": "brightBlack"
      },
      {
        "id": "7",
        "type": "separator"
      },
      {
        "id": "8",
        "type": "session-cost",
        "color": "green"
      }
    ],
    []
  ],
  "flexMode": "full-minus-40",
  "compactThreshold": 60,
  "colorLevel": 2,
  "inheritSeparatorColors": false,
  "globalBold": false,
  "powerline": {
    "enabled": false,
    "separators": [""],
    "separatorInvertBackground": [false],
    "startCaps": [],
    "endCaps": [],
    "autoAlign": false
  }
}
