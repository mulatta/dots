# Query map for aerc with notmuch
# Maps folder names to notmuch queries
#
# Flow: IMAP → Sieve (folders) → mbsync → notmuch → afew (spam)

# Folders
inbox=folder:mulatta/Inbox AND NOT tag:trash AND NOT tag:spam
dev=folder:mulatta/.Dev AND NOT tag:trash
research=folder:mulatta/.Research AND NOT tag:trash
university=folder:mulatta/.University AND NOT tag:trash
finance=folder:mulatta/.Finance AND NOT tag:trash
social=folder:mulatta/.Social AND NOT tag:trash
notifications=folder:mulatta/.Notifications AND NOT tag:trash

# Virtual
unread=tag:unread AND NOT tag:trash AND NOT tag:spam

# System
sent=folder:"mulatta/Sent Items" AND NOT tag:trash
drafts=tag:draft
junk=folder:"mulatta/Junk Mail" OR tag:spam
trash=tag:trash
all=* AND NOT tag:trash
