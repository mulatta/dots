#!/usr/bin/env bash
# zjstatus widget: show unread counts for email and ntfy topics
set -euo pipefail

NTFY_STATE_DIR="$HOME/.local/state/ntfy"
output=""

# Email: unread count from notmuch
if command -v notmuch &>/dev/null && [ -d "$HOME/mail/.notmuch" ]; then
  mail_count=$(notmuch count "tag:unread AND NOT tag:spam AND NOT tag:trash" 2>/dev/null || echo 0)
  if [ "$mail_count" -gt 0 ]; then
    output+=" ${mail_count}"
  fi
fi

# ntfy: per-topic unread counts
if [ -d "$NTFY_STATE_DIR" ]; then
  for f in "$NTFY_STATE_DIR"/*; do
    [ -f "$f" ] || continue
    topic=$(basename "$f")
    count=$(cat "$f" 2>/dev/null || echo 0)
    if [ "$count" -gt 0 ]; then
      output+="  ${topic} ${count}"
    fi
  done
fi

echo -n "$output"
