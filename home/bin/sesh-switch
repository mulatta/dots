#!/usr/bin/env bash
# Open the sesh switcher inside a tmux popup. tmux owns the border title;
# skim only handles selection so this stays independent of fzf.
set -euo pipefail

current_path=${1:-$PWD}

choice=$(
  sesh list --icons | sk \
    --no-sort --ansi --prompt '⚡  ' \
    --header '  ^a all ^t tmux ^x zoxide ^w workmux ^d kill ^f find' \
    --bind 'tab:down,btab:up' \
    --bind 'ctrl-a:change-prompt(⚡  )+reload(sesh list --icons)' \
    --bind 'ctrl-t:change-prompt(🪟  )+reload(sesh list -t --icons)' \
    --bind 'ctrl-x:change-prompt(📁  )+reload(sesh list -z --icons)' \
    --bind "ctrl-w:change-prompt(🌳  )+reload(cd $(printf '%q' "$current_path") && workmux list --json | jq -r '.[].path')" \
    --bind 'ctrl-f:change-prompt(🔎  )+reload(fd -H -d 2 -t d -E .Trash . ~)' \
    --bind 'ctrl-d:execute(tmux kill-session -t {2..})+change-prompt(⚡  )+reload(sesh list --icons)' \
    --preview-window 'right:55%' \
    --preview 'sesh preview {}'
)

if [[ -n $choice ]]; then
  sesh connect "$choice"
fi
