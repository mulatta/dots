#!/usr/bin/env bash
# zjstatus widget: show unread counts for email and ntfy topics
# Output uses zjstatus format codes (rendermode=dynamic)
# Pill style matches tab_normal: rounded powerline caps (U+E0B6/U+E0B4)
set -euo pipefail

NTFY_STATE_DIR="${XDG_STATE_HOME:-$HOME/.local/state}/ntfy"
output=""

# Two-segment rounded pill matching tab style:
#   [icon] [count]
# Uses  (U+E0B6) for left cap,  (U+E0B4) for right cap
pill() {
  local color="$1" icon="$2" count="$3"
  output+="#[bg=default,fg=${color}]#[bg=${color},fg=#1e2030,bold] ${icon} "
  output+="#[bg=#363a4f,fg=${color},bold] ${count} "
  output+="#[bg=default,fg=#363a4f]"
}

# Email: unread count from notmuch
if command -v notmuch &>/dev/null && [ -d "$HOME/mail/.notmuch" ]; then
  mail_count=$(notmuch count "tag:unread AND NOT tag:spam AND NOT tag:trash" 2>/dev/null || echo 0)
  if [ "$mail_count" -gt 0 ]; then
    pill "#f5a97f" "󰊫" "$mail_count"
    output+=" "
  fi
fi

# ntfy: per-topic unread counts (state: one file per unread message ID)
if [ -d "$NTFY_STATE_DIR" ]; then
  for topic_dir in "$NTFY_STATE_DIR"/*/; do
    [ -d "$topic_dir" ] || continue
    count=$(find "$topic_dir" -maxdepth 1 -type f 2>/dev/null | wc -l | tr -d ' ')
    if [ "$count" -gt 0 ]; then
      pill "#c6a0f6" "󰂚" "$count"
      output+=" "
    fi
  done
fi

echo -n "$output"
