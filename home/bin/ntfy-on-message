#!/usr/bin/env bash
# Handler for incoming ntfy messages (called by ntfy subscribe)
# Expects NTFY_* env vars from ntfy-sh: NTFY_ID, NTFY_TOPIC, NTFY_TITLE, NTFY_MESSAGE
set -euo pipefail

STATE_DIR="${XDG_STATE_HOME:-$HOME/.local/state}/ntfy"
TOPIC_DIR="$STATE_DIR/$NTFY_TOPIC"

# Migrate old flat file format to per-ID directory
if [ -f "$TOPIC_DIR" ]; then
  mkdir -p "${TOPIC_DIR}.new"
  while IFS= read -r id; do
    [ -n "$id" ] && touch "${TOPIC_DIR}.new/$id"
  done < "$TOPIC_DIR"
  rm -f "$TOPIC_DIR" && mv "${TOPIC_DIR}.new" "$TOPIC_DIR"
fi

# Mark as unread
mkdir -p "$TOPIC_DIR"
touch "$TOPIC_DIR/$NTFY_ID"

# Native notification
if command -v terminal-notifier &>/dev/null; then
  terminal-notifier \
    -title "${NTFY_TITLE:-$NTFY_TOPIC}" \
    -message "${NTFY_MESSAGE:-New notification}" \
    -group "ntfy-$NTFY_TOPIC" \
    -sound default || true
elif command -v notify-send &>/dev/null; then
  notify-send \
    -u normal \
    -i dialog-information \
    "${NTFY_TITLE:-$NTFY_TOPIC}" \
    "${NTFY_MESSAGE:-New notification}" || true
fi
