#!/usr/bin/env bash
set -euo pipefail

if ! command -v jj >/dev/null 2>&1; then
  echo "jj-unscope: jj not found in PATH" >&2
  exit 127
fi

jj config unset --repo 'revset-aliases."trunk()"' 2>/dev/null || true
jj config unset --repo scope.cap 2>/dev/null || true
jj config unset --repo scope.topic 2>/dev/null || true
