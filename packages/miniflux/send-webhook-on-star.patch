diff --git a/internal/integration/integration.go b/internal/integration/integration.go
index 5606aab..3e574ed 100644
--- a/internal/integration/integration.go
+++ b/internal/integration/integration.go
@@ -39,0 +40,32 @@ import (
+// SendStarredEntryWebhook sends starred entries to the configured webhook only.
+func SendStarredEntryWebhook(entry *model.Entry, userIntegrations *model.Integration) {
+	if !userIntegrations.WebhookEnabled {
+		return
+	}
+
+	var webhookURL string
+	if entry.Feed != nil && entry.Feed.WebhookURL != "" {
+		webhookURL = entry.Feed.WebhookURL
+	} else {
+		webhookURL = userIntegrations.WebhookURL
+	}
+
+	slog.Debug("Sending starred entry to Webhook",
+		slog.Int64("user_id", userIntegrations.UserID),
+		slog.Int64("entry_id", entry.ID),
+		slog.String("entry_url", entry.URL),
+		slog.String("webhook_url", webhookURL),
+	)
+
+	webhookClient := webhook.NewClient(webhookURL, userIntegrations.WebhookSecret)
+	if err := webhookClient.SendStarEntryWebhookEvent(entry); err != nil {
+		slog.Error("Unable to send starred entry to Webhook",
+			slog.Int64("user_id", userIntegrations.UserID),
+			slog.Int64("entry_id", entry.ID),
+			slog.String("entry_url", entry.URL),
+			slog.String("webhook_url", webhookURL),
+			slog.Any("error", err),
+		)
+	}
+}
+
