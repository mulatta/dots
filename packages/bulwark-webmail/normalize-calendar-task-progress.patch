+import { afterEach, beforeEach, describe, expect, it, vi } from 'vitest';
+import { JMAPClient } from '../jmap/client';
+
+function mockFetchResponse(status: number, body?: unknown): Response {
+  return new Response(body ? JSON.stringify(body) : null, {
+    status,
+    headers: { 'Content-Type': 'application/json' },
+  });
+}
+
+describe('JMAP calendar tasks', () => {
+  let fetchSpy: ReturnType<typeof vi.spyOn>;
+
+  beforeEach(() => {
+    fetchSpy = vi.spyOn(globalThis, 'fetch');
+  });
+
+  afterEach(() => {
+    fetchSpy.mockRestore();
+  });
+
+  it('normalizes uppercase cancelled progress from CalDAV-created tasks', async () => {
+    fetchSpy.mockResolvedValueOnce(mockFetchResponse(200, {
+      capabilities: {
+        'urn:ietf:params:jmap:core': {},
+        'urn:ietf:params:jmap:calendars': {},
+      },
+      accounts: { b: { name: 'test', isPersonal: true, accountCapabilities: {} } },
+      primaryAccounts: {
+        'urn:ietf:params:jmap:mail': 'b',
+        'urn:ietf:params:jmap:calendars': 'b',
+      },
+      apiUrl: 'https://mail.example.com/jmap/',
+      downloadUrl: 'https://mail.example.com/jmap/download/{accountId}/{blobId}/{name}',
+    }));
+
+    const client = new JMAPClient('https://mail.example.com', 'user@example.com', 'password');
+    await client.connect();
+    fetchSpy.mockReset();
+
+    fetchSpy
+      .mockResolvedValueOnce(mockFetchResponse(200, {
+        methodResponses: [
+          ['error', { type: 'unsupportedFilter', description: 'types' }, '0'],
+          ['error', { type: 'invalidResultReference' }, '1'],
+        ],
+      }))
+      .mockResolvedValueOnce(mockFetchResponse(200, {
+        methodResponses: [[
+          'CalendarEvent/get',
+          {
+            list: [{
+              id: 'ek',
+              '@type': 'Task',
+              uid: 'cancelled-task@example.com',
+              calendarIds: { f: true },
+              title: 'cancelled task',
+              description: '',
+              due: '2026-05-01T00:00:00',
+              start: null,
+              duration: null,
+              timeZone: null,
+              showWithoutTime: false,
+              progress: 'CANCELLED',
+              progressUpdated: null,
+              priority: 5,
+              privacy: 'public',
+              keywords: null,
+              categories: null,
+              color: null,
+              created: null,
+              updated: '2026-05-06T00:00:00Z',
+              recurrenceRules: null,
+              alerts: null,
+              relatedTo: null,
+            }],
+            notFound: [],
+          },
+          '0',
+        ]],
+      }));
+
+    const tasks = await client.getCalendarTasks();
+
+    expect(tasks).toHaveLength(1);
+    expect(tasks[0].progress).toBe('cancelled');
+
+    client.disconnect();
+  });
+});
